# Database Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/walletslotdb?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET_B64=your_jwt_secret_base64_here

# Pepper Configuration
PEPPER_CIPHER_V1=plain:your_pepper_secret_here
PEPPER_CIPHER_V0=temp

# OTP Configuration
OTP_SECRET=your_otp_secret_here

# AES Encryption
AES_BASE64_KEY=your_aes_base64_key_here

# SSAFY API Configuration
SSAFY_FINANCE_API_KEY=your_ssafy_finance_api_key_here
SSAFY_FINANCE_USER_KEY=your_ssafy_finance_user_key_here
SSAFY_GMS_KEY=your_ssafy_gms_key_here

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# FCM Configuration
FCM_PROJECT_ID=your_fcm_project_id_here
FCM_SERVICE_ACCOUNT_JSON_PATH=path/to/your/firebase-adminsdk-*.json

# Aligo SMS Configuration
ALIGO_API_KEY=your_aligo_api_key_here
ALIGO_USER_ID=your_aligo_user_id_here
ALIGO_SENDER=your_aligo_sender_phone_number_here

# Naver OCR Configuration
NAVER_OCR_INVOKE_URL=https://your-invoke-url.apigw.ntruss.com
NAVER_OCR_PROJECT_ID=your_naver_ocr_project_id_here
NAVER_OCR_PRIVATE_KEY=your_naver_ocr_private_key_here
NAVER_OCR_SECRET=your_naver_ocr_secret_here

# AWS Configuration
AWS_REGION=ap-northeast-2

# Refresh Token Configuration (Optional)
RT_HASH_PEPPER=dev-rt-pepper

# Bcrypt Cost (Optional)
BCRYPT_COST=12

